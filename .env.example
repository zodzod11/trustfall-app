# Copy to .env.local and fill in (see https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Optional public Storage bucket for portfolio images (default: portfolio)
# VITE_SUPABASE_PORTFOLIO_BUCKET=portfolio

# Match engine (server-side only — never expose in Vite client)
# Used by: npm run match-engine (see server/match-engine.ts)
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: MATCH_ENGINE_PORT=8788
