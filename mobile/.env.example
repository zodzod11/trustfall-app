# Metro inlines `EXPO_PUBLIC_*` for every platform (including web). `app.config.js` alone is not enough on web.
#
# Easiest: from repo root run:
#   npm run mobile:sync-env
# That copies `VITE_*` from `.env.local` into this file. Then restart Expo:
#   cd mobile && npx expo start --clear
#
# Or set these manually:
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# EXPO_PUBLIC_NOTIFY_API_URL=http://localhost:8787/api/notify-request
